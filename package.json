{
  "name": "type-cacheable",
  "private": true,
  "author": {
    "name": "Joshua Slate",
    "url": "https://joshuaslate.com"
  },
  "license": "MIT",
  "workspaces": {
    "packages": [
      "packages/*"
    ]
  },
  "scripts": {
    "clean": "lerna run clean --concurrency 20 --stream",
    "build": "lerna run build --concurrency 20 --stream",
    "test": "jest --coverage --runInBand --maxConcurrency=1",
    "watch": "jest --watch --runInBand",
    "pub": "lerna publish",
    "link": "lerna exec -- yarn link",
    "unlink": "lerna exec -- yarn unlink"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@types/jest": "^30.0.0",
    "lerna": "^9.0.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6"
  }
}
